# PortScope environment configuration — copy to `.env` and adjust.
# NEVER commit a real .env file. Placeholders only below.

# ---- Worker API (public API) ----
# Port the Worker API listens on locally.
PORT=3001
# URL of the trusted Scanner Agent the Worker calls over HTTP.
SCANNER_AGENT_URL=http://localhost:3002
# Allow scanning private/internal/loopback ranges. Keep false unless authorized.
LOCAL_SCAN_ENABLED=false

# ---- Scanner Agent (internal Nmap service) ----
# The Agent reads its own PORT (default 3002) and the same LOCAL_SCAN_ENABLED.
# Example when running the agent directly:
#   PORT=3002 LOCAL_SCAN_ENABLED=false npm run dev:scanner

# ---- Optional (defaults shown) ----
# SCAN_TIMEOUT_MS=60000
# RATE_LIMIT_MAX=5
# RATE_LIMIT_WINDOW_MS=300000
# HISTORY_LIMIT=50
# NMAP_BIN=nmap
# LOG_LEVEL=info
