# PortScope environment configuration — copy to `.env` and adjust.
# NEVER commit a real .env file. Placeholders only below.

# Allow scanning private/internal/loopback ranges. Keep false unless you are
# authorized to scan your own local network.
LOCAL_SCAN_ENABLED=false

# Server port.
PORT=3001

# --- Optional (defaults shown) ---
# Per-scan timeout in milliseconds.
# SCAN_TIMEOUT_MS=60000
# Rate limit: max scans per window, per IP.
# RATE_LIMIT_MAX=5
# Rate limit window in milliseconds (5 minutes).
# RATE_LIMIT_WINDOW_MS=300000
# Path to the Nmap binary (if not on PATH).
# NMAP_BIN=nmap
# Number of scans retained in the in-memory history.
# HISTORY_LIMIT=50
# Log level: trace|debug|info|warn|error.
# LOG_LEVEL=info
